{
  "manifest_version": 3,
  "name": "School Watcher",
  "version": "0.2.0",
  "description": "Detects study websites and signals a native background app.",
  "permissions": ["tabs", "alarms"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "host_permissions": ["http://127.0.0.1:42424/*"]
}

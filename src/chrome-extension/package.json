{
  "name": "school-website-watcher-extension",
  "version": "1.0.0",
  "description": "Chrome extension that watches school websites and sends events to the local system app.",
  "private": true,
  "type": "module",
  "scripts": {
    "bundle": "webpack --config webpack.config.js",
    "build": "tsc && webpack --config webpack.config.js",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
